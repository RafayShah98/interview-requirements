# Copy this file to .env and fill in your LiteAPI key.
# The .env file is listed in .gitignore and must never be committed.
#
# Alternatively, export the variable in your shell:
#   export LITEAPI_KEY=your_api_key_here
#
# Or create app/src/main/resources/application.properties with:
#   LITEAPI_KEY=your_api_key_here

LITEAPI_KEY=your_api_key_here
